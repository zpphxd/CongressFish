# CongressFish Configuration

## LLM & Embedding (Ollama)
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# For CAMEL-AI (used by OASIS simulation)
OPENAI_API_KEY=ollama
OPENAI_API_BASE_URL=http://localhost:11434/v1

## Neo4j (Local)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

## Congress Data APIs

# Congress.gov API (free, get key at https://api.data.gov/signup/)
CONGRESS_GOV_API_KEY=your_congress_gov_api_key

# OpenFEC API (free, get key at https://api.open.fec.gov/developers/)
OPENFEC_API_KEY=your_openfec_api_key

# Quiver Quantitative (for congressional stock trades; optional, has free tier)
# Get key at https://www.quiverquant.com/api/
QUIVER_API_KEY=your_quiver_api_key

## Flask Configuration (Optional)
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=False

## Ollama Configuration (Optional)
OLLAMA_NUM_CTX=8192

## OASIS Simulation Configuration (Optional)
OASIS_DEFAULT_MAX_ROUNDS=10
